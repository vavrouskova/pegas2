APP_ENV=local # production, development, local, etc...
APP_NAME=pegas

NEXT_PUBLIC_FRONTEND_URL=https://www.pohrebpegas.cz/
NEXT_PUBLIC_BACKEND_URL=https://wp.pohrebpegas.cz/cz/

GTM_ID=

# WordPress GraphQL API Configuration
NEXT_PUBLIC_GRAPHQL_URL=https://wp.pohrebpegas.cz/cz/graphql

# WordPress API (server-only, no NEXT_PUBLIC_ prefix)
WORDPRESS_API_KEY=

# Preview / Draft Mode (server-only, no NEXT_PUBLIC_ prefix)
NEXT_PREVIEW_KEY=
GRAPHQL_PREVIEW_KEY=
WP_PREVIEW_USER=
WP_PREVIEW_PASSWORD=

# Cloudflare cache purge configuration
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_PURGE_URL=
CLOUDFLARE_PURGE_MODE=hosts
CLOUDFLARE_PURGE_TARGETS=["www.pohrebpegas.cz","stg.pohrebpegas.cz"]
CLOUDFLARE_PURGE_ON_MANUAL_ONLY=false
