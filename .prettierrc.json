{
  "trailingComma": "es5",
  "semi": true,
  "tabWidth": 2,
  "singleQuote": true,
  "jsxSingleQuote": true,
  "plugins": ["prettier-plugin-tailwindcss"],
  "tailwindFunctions": ["cva", "clsx"],
  "tailwindPreserveWhitespace": true,
  "tailwindPreserveDuplicates": true,
  "singleAttributePerLine": true,
  "bracketSpacing": true,
  "printWidth": 120
}
